{
  "package": {
    "name": "zero-agent",
    "version": "0.0.1",
    "license": "AGPL-3.0",
    "description": "Hermes-inspired daily-use agent built primarily in Zero"
  },
  "targets": {
    "cli": {
      "kind": "exe",
      "main": "src/main.0"
    }
  },
  "profiles": {
    "dev": {
      "inherits": "dev"
    },
    "release": {
      "inherits": "small"
    },
    "fast": {
      "inherits": "fast"
    },
    "tiny": {
      "inherits": "tiny"
    }
  },
  "capabilities": {
    "filesystem": ["read", "write"],
    "env": ["read"],
    "process": ["spawn", "exec"],
    "network": ["https"],
    "terminal": ["raw", "ansi"]
  },
  "diagnostics": {
    "format": "json",
    "explain": true,
    "fix": true
  }
}
