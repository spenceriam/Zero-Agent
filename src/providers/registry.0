use core.events

pub shape ProviderCapability {
    streaming: Bool,
    tool_calling: Bool,
    thinking_events: Bool,
    model_discovery: Bool,
}

pub shape Provider {
    id: String,
    display_name: String,
    capability: ProviderCapability,
}

pub fun openRouterProvider() -> Provider {
    let cap = ProviderCapability { streaming: true, tool_calling: true, thinking_events: false, model_discovery: true }
    return Provider { id: "openrouter", display_name: "OpenRouter", capability: cap }
}

pub fun anthropicProvider() -> Provider {
    let cap = ProviderCapability { streaming: true, tool_calling: true, thinking_events: true, model_discovery: false }
    return Provider { id: "anthropic", display_name: "Anthropic", capability: cap }
}

pub fun openaiProvider() -> Provider {
    let cap = ProviderCapability { streaming: true, tool_calling: true, thinking_events: false, model_discovery: true }
    return Provider { id: "openai", display_name: "OpenAI", capability: cap }
}

pub fun stubProvider() -> Provider {
    let cap = ProviderCapability { streaming: false, tool_calling: true, thinking_events: false, model_discovery: false }
    return Provider { id: "stub", display_name: "Stub (testing)", capability: cap }
}

pub fun stubStreamResponse() -> AgentEvent {
    return makeAssistantText("This is a stub response from the provider registry.")
}

pub fun stubToolCall() -> AgentEvent {
    return makeToolCall("read_file", "example.txt")
}
