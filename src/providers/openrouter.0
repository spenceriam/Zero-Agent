use core.config
use core.events
use providers.openai

pub shape OpenRouterConfig {
    base_url: String,
    api_key_env: String,
    default_model: String,
}

pub fun defaultConfig() -> OpenRouterConfig {
    return OpenRouterConfig {
        base_url: "https://openrouter.ai/api/v1",
        api_key_env: "OPENROUTER_API_KEY",
        default_model: "anthropic/claude-sonnet-4",
    }
}

pub fun buildRequest(model: String, messages: String, tools: String) -> openai.OpenAIRequest {
    return openai.buildRequest(model, messages, tools)
}

pub fun provider() -> config.ProviderConfig {
    return config.defaultOpenRouterProvider()
}
