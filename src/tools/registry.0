use core.types

pub shape Tool {
    name: String,
    description: String,
    risk: RiskLevel,
    input_schema: String,
}

pub fun needsApproval(tool: Tool) -> Bool {
    return false
}

pub fun readFileTool() -> Tool {
    return Tool { name: "read_file", description: "Read file contents", risk: RiskLevel.Safe, input_schema: "path:string" }
}

pub fun writeFileTool() -> Tool {
    return Tool { name: "write_file", description: "Write file contents", risk: RiskLevel.Mutating, input_schema: "path:string,contents:string" }
}

pub fun editFileTool() -> Tool {
    return Tool { name: "edit_file", description: "Edit file with search-replace", risk: RiskLevel.Mutating, input_schema: "path:string,old_string:string,new_string:string" }
}

pub fun shellTool() -> Tool {
    return Tool { name: "shell", description: "Run shell command", risk: RiskLevel.Mutating, input_schema: "command:string" }
}

pub fun globTool() -> Tool {
    return Tool { name: "glob", description: "Find files by pattern", risk: RiskLevel.Safe, input_schema: "pattern:string" }
}
