use core.events

pub shape TuiLayout {
    conversation: String,
    activity: String,
    input: String,
}

pub fun defaultLayout() -> TuiLayout {
    return TuiLayout {
        conversation: "conversation",
        activity: "activity",
        input: "input",
    }
}

pub fun renderEvent(event: AgentEvent) -> String {
    return event.text
}
