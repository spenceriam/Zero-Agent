pub shape GatewayMessage {
    platform: String,
    chat_id: String,
    user_id: String,
    text: String,
}

pub fun telegramMessage(chat_id: String, user_id: String, text: String) -> GatewayMessage {
    return GatewayMessage {
        platform: "telegram",
        chat_id: chat_id,
        user_id: user_id,
        text: text,
    }
}
