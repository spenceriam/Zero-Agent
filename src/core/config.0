pub shape ProviderConfig {
    id: String,
    name: String,
    api_format: String,
    base_url: String,
    api_key: String,
    default_model: String,
}

pub shape ToolPolicyConfig {
    allow_safe_without_prompt: Bool,
    ask_before_mutating: Bool,
    ask_before_destructive: Bool,
}

pub shape TelegramConfig {
    bot_token: String,
    allowed_users: String,
}

pub shape AppConfig {
    data_dir: String,
    default_provider: String,
    tool_policy: ToolPolicyConfig,
    telegram: TelegramConfig,
}

pub fun defaultToolPolicy() -> ToolPolicyConfig {
    return ToolPolicyConfig { allow_safe_without_prompt: true, ask_before_mutating: true, ask_before_destructive: true }
}

pub fun defaultTelegram() -> TelegramConfig {
    return TelegramConfig { bot_token: "", allowed_users: "" }
}

pub fun defaultProvider() -> ProviderConfig {
    return ProviderConfig { id: "openrouter", name: "OpenRouter", api_format: "openai", base_url: "https://openrouter.ai/api/v1", api_key: "", default_model: "anthropic/claude-sonnet-4" }
}

pub fun isConfigValid(config: AppConfig) -> Bool {
    return config.data_dir != "" && config.default_provider != ""
}
