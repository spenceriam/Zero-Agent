use core.types

pub enum AgentEventKind {
    UserInput,
    ProviderText,
    AssistantText,
    ToolCall,
    ToolResult,
    Status,
    Error,
    Done,
}

pub shape AgentEvent {
    kind: AgentEventKind,
    text: String,
    tool_name: String,
}

pub fun makeUserInput(text: String) -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.UserInput, text: text, tool_name: "" }
}

pub fun makeAssistantText(text: String) -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.AssistantText, text: text, tool_name: "" }
}

pub fun makeToolCall(name: String, text: String) -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.ToolCall, text: text, tool_name: name }
}

pub fun makeToolResult(name: String, text: String) -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.ToolResult, text: text, tool_name: name }
}

pub fun makeStatus(text: String) -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.Status, text: text, tool_name: "" }
}

pub fun makeError(text: String) -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.Error, text: text, tool_name: "" }
}

pub fun makeDone() -> AgentEvent {
    return AgentEvent { kind: AgentEventKind.Done, text: "", tool_name: "" }
}
