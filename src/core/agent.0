use core.events
use core.session
use core.types

pub shape AgentState {
    session_id: String,
    provider_id: String,
    model: String,
    messages: String,
    is_running: Bool,
}

pub fun newAgentState(session_id: String, provider: String, model: String) -> AgentState {
    return AgentState { session_id: session_id, provider_id: provider, model: model, messages: "", is_running: false }
}

pub fun handleUserInput(text: String) -> AgentEvent {
    return makeUserInput(text)
}

pub fun processAssistantText(text: String) -> AgentEvent {
    return makeAssistantText(text)
}

pub fun processToolCall(name: String, input: String) -> AgentEvent {
    return makeToolCall(name, input)
}

pub fun processToolResult(name: String, output: String) -> AgentEvent {
    return makeToolResult(name, output)
}

pub fun agentReady() -> AgentEvent {
    return makeStatus("Zero-Agent ready")
}
