use core.config
use core.events
use providers.openai

pub shape OllamaConfig {
    base_url: String,
    default_model: String,
}

pub fun defaultConfig() -> OllamaConfig {
    return OllamaConfig {
        base_url: "http://localhost:11434/v1",
        default_model: "llama3.2",
    }
}

pub fun buildRequest(model: String, messages: String, tools: String) -> openai.OpenAIRequest {
    return openai.buildRequest(model, messages, tools)
}

pub fun provider() -> config.ProviderConfig {
    return config.ProviderConfig {
        id: "ollama",
        display_name: "Ollama",
        api_kind: "openai-compatible",
        base_url: "http://localhost:11434/v1",
        api_key_env: "",
    }
}
