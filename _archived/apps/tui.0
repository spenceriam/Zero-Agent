use core.events
use core.types

pub enum Pane {
    Conversation,
    Activity,
    Input,
}

pub enum ApprovalChoice {
    Approve,
    Deny,
    AlwaysApprove,
}

pub shape TuiLayout {
    conversation: String,
    activity: String,
    input: String,
    active_pane: Pane,
}

pub shape RenderLine {
    text: String,
    kind: AgentEventKind,
}

pub shape ThinkingPanel {
    visible: Bool,
    content: String,
}

pub shape ProgressState {
    active: Bool,
    message: String,
}

pub shape ApprovalPrompt {
    visible: Bool,
    tool_name: String,
    description: String,
    risk: RiskLevel,
}

pub shape InputState {
    text: String,
    cursor: Int,
}

pub fun defaultLayout() -> TuiLayout {
    return TuiLayout {
        conversation: "conversation",
        activity: "activity",
        input: "input",
        active_pane: Pane.Conversation,
    }
}

pub fun defaultInput() -> InputState {
    return InputState {
        text: "",
        cursor: 0,
    }
}

pub fun renderEvent(event: AgentEvent) -> RenderLine {
    return RenderLine {
        text: event.text,
        kind: event.kind,
    }
}

pub fun renderAssistantText(text: String) -> RenderLine {
    return RenderLine {
        text: text,
        kind: AgentEventKind.AssistantText,
    }
}

pub fun renderThinking(text: String) -> ThinkingPanel {
    return ThinkingPanel {
        visible: true,
        content: text,
    }
}

pub fun renderProgress(message: String) -> ProgressState {
    return ProgressState {
        active: true,
        message: message,
    }
}

pub fun renderStatus(text: String) -> RenderLine {
    return RenderLine {
        text: text,
        kind: AgentEventKind.Status,
    }
}

pub fun renderError(text: String) -> RenderLine {
    return RenderLine {
        text: text,
        kind: AgentEventKind.Error,
    }
}

pub fun renderApproval(tool_name: String, description: String, risk: RiskLevel) -> ApprovalPrompt {
    return ApprovalPrompt {
        visible: true,
        tool_name: tool_name,
        description: description,
        risk: risk,
    }
}

pub fun hideApproval() -> ApprovalPrompt {
    return ApprovalPrompt {
        visible: false,
        tool_name: "",
        description: "",
        risk: RiskLevel.Safe,
    }
}
